# Gmail IMAP (connessione)
# Usa l'email completa dell'account Google e una App Password (16 caratteri),
# NON la password Gmail normale. Richiede verifica in 2 passaggi attiva.
# In Gmail: Impostazioni → Inoltro e POP/IMAP → Abilita IMAP.
# Se vedi AUTHENTICATIONFAILED: controlla che non ci siano virgolette nel valore
# su Render, che IMAP sia abilitato e che Protezione avanzata sia disattivata.
GMAIL_ADDRESS=tua.email@gmail.com
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# Opzionali
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_MAILBOX=INBOX

# Pipeline: legacy (main.py) oppure agent (main_agent.py)
MATCHER_MODE=legacy

# Expedia EG*TRVL: regex (default) oppure llm
EXPEDIA_MATCHER=regex

# OpenAI (richiesto per EXPEDIA_MATCHER=llm e per main_agent.py)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
# Opzionale: endpoint alternativo (proxy/Azure)
# OPENAI_BASE_URL=
# SSL: su Windows con proxy/antivirus che intercetta HTTPS, se vedi "Connection error":
# OPENAI_VERIFY_SSL=false
# oppure percorso al certificato root aziendale:
# OPENAI_CA_BUNDLE=C:/path/to/corp-root.pem
# Opzionale: tariffa USD per 1M token (sovrascrive il default del modello)
# OPENAI_PRICE_INPUT_PER_1M=0.75
# OPENAI_PRICE_OUTPUT_PER_1M=4.5
# Transazioni per chiamata LLM (1 = sequenziale, 8 = default batch)
EXPEDIA_LLM_BATCH_SIZE=8

# Agente LangChain (main_agent.py)
AGENT_MAX_ITERATIONS=12
AGENT_DATE_WINDOW_DAYS=7
# Rate limit OpenAI (TPM): retry automatico su 429; delay opzionale tra transazioni
AGENT_RATE_LIMIT_MAX_RETRIES=8
# Secondi di pausa tra una transazione e la successiva (0 = disabilitato; prova 1-2 se vedi 429)
AGENT_TXN_DELAY_SECONDS=0
AGENT_LOG_LEVEL=INFO
AGENT_LOG_DIR=logs
AGENT_LOG_LLM_BODY=false
AGENT_LOG_EMAIL_BODY=false

# Dashboard web (main_dashboard.py / Docker)
DASHBOARD_PORT=8000
# DASHBOARD_RELOAD=true

# Docker Compose: copia questo file in .env e compila OPENAI_API_KEY (+ Gmail se serve)
#   docker compose up --build
# Dashboard su http://localhost:8000

# Render: render.yaml in repo → Blueprint
#   https://dashboard.render.com/blueprint/new?repo=https://github.com/dadapera/trans-matching
# Compila OPENAI_API_KEY e Gmail nel Dashboard dopo Apply.

# MSC email (stub — completare quando noti mittente/campi)
MSC_EMAIL_FROM=msc-booking.no-reply@msccrociere.it
MSC_SEARCH_DAYS=5
MSC_SEARCH_KEYWORDS=MSC,crociera,booking
